generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Cliente {
  id        String   @id @default(cuid())
  nombre    String
  email     String?
  telefono  String?
  empresa   String?
  notas     String?
  creadoEn  DateTime @default(now())
  updatedAt DateTime @updatedAt

  pagos PagoCliente[]
}

model Cuenta {
  id               String   @id @default(cuid())
  nombre           String   @unique
  moneda           String   @default("USD")
  notas            String?
  creadoEn         DateTime @default(now())

  pagosClientes    PagoCliente[]
  pagosProveedores PagoProveedor[]
}

model PagoCliente {
  id          String     @id @default(cuid())
  clienteId   String
  cuentaId    String
  monto       Decimal    @db.Decimal(15, 2)
  moneda      String     @default("USD")
  fecha       DateTime
  descripcion String?
  estado      EstadoPago @default(PENDIENTE)
  creadoEn    DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  cliente       Cliente        @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  cuenta        Cuenta         @relation(fields: [cuentaId], references: [id], onDelete: Restrict)
  comisiones    Comision[]
  entradasFondo EntradaFondo[]
}

model Proveedor {
  id        String   @id @default(cuid())
  nombre    String
  email     String?
  servicio  String?
  notas     String?
  creadoEn  DateTime @default(now())
  updatedAt DateTime @updatedAt

  pagos PagoProveedor[]
}

model PagoProveedor {
  id          String     @id @default(cuid())
  proveedorId String
  cuentaId    String
  monto       Decimal    @db.Decimal(15, 2)
  moneda      String     @default("USD")
  fecha       DateTime
  descripcion String?
  estado      EstadoPago @default(PENDIENTE)
  creadoEn    DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  proveedor     Proveedor      @relation(fields: [proveedorId], references: [id], onDelete: Restrict)
  cuenta        Cuenta         @relation(fields: [cuentaId], references: [id], onDelete: Restrict)
  comisiones    Comision[]
  entradasFondo EntradaFondo[]
}

model Comision {
  id               String   @id @default(cuid())
  descripcion      String
  monto            Decimal  @db.Decimal(15, 2)
  moneda           String   @default("USD")
  pagoClienteId    String?
  pagoProveedorId  String?
  creadoEn         DateTime @default(now())

  pagoCliente   PagoCliente?   @relation(fields: [pagoClienteId], references: [id], onDelete: Cascade)
  pagoProveedor PagoProveedor? @relation(fields: [pagoProveedorId], references: [id], onDelete: Cascade)
}

model EntradaFondo {
  id              String      @id @default(cuid())
  tipo            TipoEntrada
  monto           Decimal     @db.Decimal(15, 2)
  moneda          String      @default("USD")
  descripcion     String?
  fecha           DateTime
  pagoClienteId   String?
  pagoProveedorId String?
  bucketId        String?
  creadoEn        DateTime    @default(now())

  pagoCliente   PagoCliente?   @relation(fields: [pagoClienteId], references: [id], onDelete: SetNull)
  pagoProveedor PagoProveedor? @relation(fields: [pagoProveedorId], references: [id], onDelete: SetNull)
  bucket        BucketFondo?   @relation(fields: [bucketId], references: [id], onDelete: SetNull)
}

model BucketFondo {
  id          String   @id @default(cuid())
  nombre      String   @unique
  descripcion String?
  creadoEn    DateTime @default(now())

  entradas EntradaFondo[]
}

enum EstadoPago {
  PENDIENTE
  COMPLETADO
  CANCELADO
}

enum TipoEntrada {
  INGRESO
  EGRESO
  ASIGNACION
}
